{
  "name": "local-llm-claude-code",
  "build": { "dockerfile": "Dockerfile" },
  "runArgs": ["--gpus=all"],
  "hostRequirements": { "gpu": "optional" },
  "mounts": [
    "source=ollama-models,target=/root/.ollama,type=volume",
    "source=coderouter-config,target=/root/.coderouter,type=volume"
  ],
  "postStartCommand": "/entrypoint.sh &",
  "remoteEnv": {
    "ANTHROPIC_BASE_URL": "http://localhost:8088",
    "ANTHROPIC_AUTH_TOKEN": "dummy"
  },
  "forwardPorts": [8088, 11434]
}